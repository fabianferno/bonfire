# LLM provider: 'zerog' or 'openai-compatible'
LLM_PROVIDER=zerog

# 0G Compute (required when LLM_PROVIDER=zerog)
# Default: 0G Aristotle mainnet (chainId 16661).
# For Galileo testnet, set OG_RPC_URL=https://evmrpc-testnet.0g.ai (chainId 16602).
OG_RPC_URL=https://evmrpc.0g.ai
DEPLOYER_PRIVATE_KEY=0x...
# Optional: pin to a specific 0G inference provider address (otherwise auto-pick)
OG_BROKER_PROVIDER=

# OpenAI-compatible fallback (required when LLM_PROVIDER=openai-compatible)
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-...
LLM_MODEL=gpt-4o-mini

# Embeddings (optional — leave blank to disable vector memory)
EMBEDDINGS_BASE_URL=
EMBEDDINGS_API_KEY=
EMBEDDINGS_MODEL=

# Telegram
TELEGRAM_BOT_TOKEN=

# Web tools
TAVILY_API_KEY=

# Server
AGENT_API_PORT=7777
LOG_LEVEL=info
