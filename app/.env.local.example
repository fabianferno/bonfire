# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and never committed.

# Privy app ID — get yours at https://console.privy.io
# Required for the Privy auth modal (email, Google, wallet sign-in).
NEXT_PUBLIC_PRIVY_APP_ID=

# BonFire backend base URL (no trailing slash).
# Defaults to http://localhost:8080 when not set.
NEXT_PUBLIC_BONFIRE_BASE_URL=http://localhost:8080

# ember-agent base URL used when creating a new agent (hidden from the UI).
# Defaults to http://localhost:7777 when not set.
NEXT_PUBLIC_AGENT_BASE_URL=http://localhost:7777

# INFT contract on 0G. Set after deploying BonFireAgentINFT via
#   cd contracts && pnpm hardhat run scripts/deploy.ts --network ogMainnet
NEXT_PUBLIC_INFT_CONTRACT_ADDRESS=

# 0G chain target (Aristotle mainnet defaults).
# For Galileo testnet: chainId=16602, rpc=https://evmrpc-testnet.0g.ai,
# explorer=https://chainscan-galileo.0g.ai, name="0G Galileo Testnet".
NEXT_PUBLIC_OG_CHAIN_ID=16661
NEXT_PUBLIC_OG_RPC_URL=https://evmrpc.0g.ai
NEXT_PUBLIC_OG_EXPLORER_URL=https://chainscan.0g.ai
NEXT_PUBLIC_OG_NETWORK_NAME=0G Aristotle Mainnet
