# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and never committed.

# Privy app ID — get yours at https://console.privy.io
# Required for the Privy auth modal (email, Google, wallet sign-in).
NEXT_PUBLIC_PRIVY_APP_ID=

# BonFire backend base URL (no trailing slash).
# Defaults to http://localhost:8080 when not set.
NEXT_PUBLIC_BONFIRE_BASE_URL=http://localhost:8080

# ember-agent base URL used when creating a new agent (hidden from the UI).
# Defaults to http://localhost:7777 when not set.
NEXT_PUBLIC_AGENT_BASE_URL=http://localhost:7777

# INFT contract on 0G testnet (chainId 16601). Set after deploying
# the BonFireAgentINFT contract via `pnpm --filter bonfire-contracts deploy:ogtestnet`.
NEXT_PUBLIC_INFT_CONTRACT_ADDRESS=
NEXT_PUBLIC_OG_CHAIN_ID=16602
