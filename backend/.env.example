# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=bonfire
# DEV only — ephemeral in-process Mongo (no Docker / mongod): `npm run dev:no-docker` sets this.
# DEV_MEMORY_MONGO=1

# Auth — JWT_SECRET must be at least 32 chars; boot fails otherwise.
# JWT is still used by ember-agent's BONFIRE_AGENT_KEY flow; Privy is the user-facing auth.
JWT_SECRET=replace-me-with-a-long-random-secret-at-least-32-chars
JWT_EXPIRES_IN=7d

# Server
PORT=8080
LOG_LEVEL=info

# Cascade limits (defaults shown)
MAX_CASCADE_HOPS=5
MAX_INVOCATIONS_PER_ROOT=20

# Privy auth (required when frontend is using Privy SDK).
# Get these from https://dashboard.privy.io after creating an app.
PRIVY_APP_ID=
PRIVY_APP_SECRET=

# Extra CORS origins (comma-separated). Dev also allows any localhost / 127.0.0.1 origin when NODE_ENV is not production.
# CORS_ORIGINS=https://your-frontend.vercel.app

# 0G testnet RPC (defaults to https://evmrpc-testnet.0g.ai)
OG_RPC_URL=https://evmrpc-testnet.0g.ai

# INFT integration — when all three of (INFT_CONTRACT_ADDRESS,
# PLATFORM_EXECUTOR_PRIVATE_KEY) are set, the backend wires up the chain
# client, 0G Storage, and chain-event indexer at boot. Otherwise the runtime
# falls back to legacy slug-based agent invocation (no INFT gate, no decrypt).
INFT_CONTRACT_ADDRESS=
# Platform-executor wallet — owns the ECIES private key used to decrypt every
# agent's data-encryption-key. KEEP SECRET. In production use KMS or a secrets manager.
PLATFORM_EXECUTOR_PRIVATE_KEY=

# 0G Storage — set to 1 to use filesystem mock at backend/.storage-mock/
# (no network calls). Required for tests; convenient for local dev without 0G credentials.
OG_STORAGE_MOCK=0

# Seed migration script (backend/scripts/mint-seed-agents.mjs) only.
# Wallet that will own the 8 seed agents minted from tenants.json.
# Must be funded with ~5 OG before running the script.
SEED_OWNER_PRIVATE_KEY=
