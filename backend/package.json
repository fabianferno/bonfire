{
  "name": "bonfire-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "@noble/ciphers": "^2.2.0",
    "@noble/hashes": "^2.2.0",
    "@noble/secp256k1": "^3.1.0",
    "@privy-io/server-auth": "^1.32.5",
    "argon2": "^0.41.1",
    "dotenv": "^16.4.0",
    "ethers": "^6.16.0",
    "hono": "^4.6.0",
    "jose": "^5.9.0",
    "lru-cache": "^11.3.6",
    "mongodb": "^6.10.0",
    "pino": "^9.5.0",
    "uuid": "^14.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.16.0",
    "@types/uuid": "^11.0.0",
    "mongodb-memory-server": "^10.1.2",
    "pino-pretty": "^11.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "argon2",
      "mongodb-memory-server"
    ]
